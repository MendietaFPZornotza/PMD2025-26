<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/xehetasunak"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/textIzenburua"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/grisa"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textEgilea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/grisa" />

    <TextView
        android:id="@+id/textPrezioa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/grisa" />

    <Button
        android:id="@+id/xehetasunak2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/urdina"
        android:text="Ikusi xehetasunak"
        android:textColor="@color/txuria" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/black" />
</LinearLayout>
