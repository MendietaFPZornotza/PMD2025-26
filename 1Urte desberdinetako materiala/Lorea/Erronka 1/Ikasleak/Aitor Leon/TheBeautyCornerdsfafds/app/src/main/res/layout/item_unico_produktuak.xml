<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/nude_larrosa"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Linear layout-a Constraint Layout-aren barruan -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Produktuaren izena idazteko eremua -->
        <TextView
            android:id="@+id/txtProdIzena"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/beltza"
            android:textSize="20sp"/>

        <!-- Produktuaren mota idazteko eremua -->
        <TextView
            android:id="@+id/txtProdMota"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/beltza"
            android:textSize="20sp"/>

        <!-- Produktuaren prezioa idazteko eremua -->
        <TextView
            android:id="@+id/txtProdPrezioa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/beltza"
            android:textSize="20sp"/>

        <!-- Botoientzako layout horizontala sortu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_horizontal">

            <!-- Editatzeko botoia -->
            <Button
                android:id="@+id/btnAukeratu"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/button_rounded_border_black"
                android:text="Editatu"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />

            <!-- Borratzeko botoia -->
            <Button
                android:id="@+id/btnBorratu"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_rounded_border_red"
                android:text="Borratu"
                android:textColor="@color/white"
                android:textAllCaps="false" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/beltza" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
