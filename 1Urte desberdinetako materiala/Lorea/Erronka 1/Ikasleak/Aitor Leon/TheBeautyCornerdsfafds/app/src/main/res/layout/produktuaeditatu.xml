<?xml version="1.0" encoding="utf-8"?>
<!-- Produktua editatzeko layout-a -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nude_larrosa"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Izena etiketa izena idazteko eremuarekin -->
    <LinearLayout
        android:id="@+id/layoutIzena"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Izena:"
            android:textSize="20sp"
            android:gravity="center_vertical" />

        <EditText
            android:id="@+id/edtIzena"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:layout_weight="0.7"
            android:padding="16dp" />
    </LinearLayout>

    <!-- Spinner Mota -->
    <Spinner
        android:id="@+id/spinnerMota"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutIzena"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="16dp"
        android:spinnerMode="dropdown" />

    <!-- Markaren layout-a bere etiketarekin -->
    <LinearLayout
        android:id="@+id/layoutMarka"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/spinnerMota"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Marka:"
            android:textSize="20sp"
            android:gravity="center_vertical" />

        <EditText
            android:id="@+id/edtMarka"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:layout_weight="0.7"
            android:padding="16dp" />
    </LinearLayout>

    <!-- Jatorriaren checkbox-ak aukeratzeko layout-a -->
    <LinearLayout
        android:id="@+id/layoutJatorria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/layoutMarka"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <CheckBox
            android:id="@+id/checkboxMongolia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mongolia"
            android:textSize="18sp" />

        <CheckBox
            android:id="@+id/checkboxNigeria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nigeria"
            android:textSize="18sp" />

        <CheckBox
            android:id="@+id/checkboxAmorebieta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amorebieta"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Produktuaren prezioaren layout-a etiketarekin -->
    <LinearLayout
        android:id="@+id/layoutPrezioa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/layoutJatorria"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prezioa:"
            android:textSize="20sp"
            android:gravity="center_vertical" />

        <EditText
            android:id="@+id/edtPrezioa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:layout_weight="0.7"
            android:padding="16dp" />
    </LinearLayout>

    <!-- Eskuragarritasunaren layout-a -->
    <LinearLayout
        android:id="@+id/layoutEskuragarritasuna"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/layoutPrezioa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <CheckBox
            android:id="@+id/checkboxEskuragarritasuna"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eskuragarritasuna"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Eguneratzeko botoia -->
    <Button
        android:id="@+id/btnEguneratu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:padding="10dp"
        android:background="@drawable/button_rounded_border_black"
        android:text="@string/prodEguneratu"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textAllCaps="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutEskuragarritasuna" />

</androidx.constraintlayout.widget.ConstraintLayout>