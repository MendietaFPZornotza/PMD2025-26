<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="root-pane" stylesheets="@../../../../styles/erabiltzaileak.css" xmlns="http://javafx.com/javafx/21.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.beginsecure.mahaigaineko_app.controller.users.ErabiltzaileakController">

    <!-- HEADER -->
    <HBox prefHeight="70" styleClass="header" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <padding>
            <Insets bottom="20" left="30" right="30" top="20" />
        </padding>

        <children>
            <Label styleClass="header-title" text="Erabiltzaileak" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="logo-text" text="EkiTop!" />
        </children>
    </HBox>

    <VBox fx:id="erabiltzaileakPane" fillWidth="true" spacing="20" styleClass="main-content" AnchorPane.topAnchor="85.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <!-- MiniCards -->
        <HBox spacing="15">
            <VBox alignment="CENTER_LEFT" spacing="6" styleClass="miniCard-blue" HBox.hgrow="ALWAYS">
                <Label styleClass="miniCard-title" text="Erabiltzaile guztiak" />
                <Label fx:id="lblTotalUsers" styleClass="miniCard-value" text="—" />
            </VBox>

            <VBox alignment="CENTER_LEFT" spacing="6" styleClass="miniCard-purple" HBox.hgrow="ALWAYS">
                <Label styleClass="miniCard-title" text="Administratzaileak" />
                <Label fx:id="lblAdmins" styleClass="miniCard-value" text="—" />
            </VBox>

        </HBox>

        <!-- Botón añadir usuario -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label styleClass="section-title" text="Kudeatu erabiltzaile guztiak" />
            <Button onAction="#btnAddUser" styleClass="btnGehitu" text="+ Erabiltzaile berria gehitu" />
        </HBox>

        <!-- Buscador y filtro -->
        <HBox spacing="15">
            <TextField fx:id="textFieldBilatuErabiltzailea" promptText="🔍 Bilatu erabiltzailea..." styleClass="searchField" HBox.hgrow="ALWAYS" />
            <Button onAction="#btnFiltratuErabiltzaileak" styleClass="btnFiltroak" text="🔽 Filtratu" />
        </HBox>

        <!-- Tabla de usuarios -->
        <TableView fx:id="erabiltzaileakTaula" styleClass="modernTable">
            <columns>
                <TableColumn fx:id="colErabiltzailea" text="ERABILTZAILEA" />
                <TableColumn fx:id="colRola" text="ROLA" />
                <TableColumn fx:id="colAzkenSaioa" text="AZKEN SAIOA" />
                <TableColumn fx:id="colEkintzak" text="EKINTZAK" />
            </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
        </TableView>
    </VBox>
</AnchorPane>
