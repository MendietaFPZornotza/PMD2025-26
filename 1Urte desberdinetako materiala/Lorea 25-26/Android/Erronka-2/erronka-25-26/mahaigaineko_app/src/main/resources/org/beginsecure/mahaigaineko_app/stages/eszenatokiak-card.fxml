<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox fx:id="root"
      spacing="10"
      styleClass="card-root"
      stylesheets="@../../../../styles/eszenatoki-card.css"
      xmlns="http://javafx.com/javafx/21.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.beginsecure.mahaigaineko_app.controller.stages.EszenatokiCardController">

    <!-- HEADER -->
    <StackPane fx:id="headerPane" styleClass="card-header">
        <padding>
            <Insets top="14" right="14" bottom="14" left="14"/>
        </padding>

        <children>
            <VBox spacing="6">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <SVGPath styleClass="header-icon"
                             content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/>

                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="nameLabel" styleClass="header-title" text="Kursaal Auditorium"/>
                        <Label fx:id="typeLabel" styleClass="header-subtitle" text="Auditorium"/>
                    </VBox>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <SVGPath fx:id="btnEdit" onMouseClicked="#onEdit" styleClass="header-action"
                                 content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm2.92 2.83H5v-.92l9.06-9.06.92.92L5.92 20.08zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                        <SVGPath fx:id="btnDelete" onMouseClicked="#onDelete" styleClass="header-action"
                                 content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zm2.46-7.12 1.41-1.41L12 12.59l2.12-2.12 1.41 1.41L13.41 14l2.12 2.12-1.41 1.41L12 15.41l-2.12 2.12-1.41-1.41L10.59 14 8.46 11.88zM15.5 4l-1-1h-5l-1 1H5v2h14V4z"/>
                    </HBox>
                </HBox>

            </VBox>
        </children>
    </StackPane>

    <!-- BODY -->
    <VBox spacing="10" styleClass="card-body">
        <padding>
            <Insets top="2" right="14" bottom="14" left="14"/>
        </padding>

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="row">
            <SVGPath styleClass="row-icon"
                     content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
            <Label fx:id="addressLabel" styleClass="row-text" text="..." wrapText="true"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="row">
            <SVGPath styleClass="row-icon"
                     content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zM8 11c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
            <Label fx:id="capacityLabel" styleClass="row-text" text="..."/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="row">
            <SVGPath styleClass="row-icon"
                     content="M7 11h2V9H7v2zm0 4h2v-2H7v2zm4 0h2v-2h-2v2zm0-4h2V9h-2v2zm4 0h2V9h-2v2zM19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 18H5V8h14v13z"/>
            <Label fx:id="eventsLabel" styleClass="row-text" text="..." wrapText="true"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="row">
            <SVGPath styleClass="row-icon"
                     content="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.07 21 3 13.93 3 5a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.59a1 1 0 0 1-.25 1.01l-2.2 2.19z"/>
            <Label fx:id="phoneLabel" styleClass="row-text" text="..."/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="row">
            <SVGPath styleClass="row-icon"
                     content="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
            <Hyperlink fx:id="emailLabel" styleClass="row-link" text="..."/>
        </HBox>
    </VBox>

</VBox>