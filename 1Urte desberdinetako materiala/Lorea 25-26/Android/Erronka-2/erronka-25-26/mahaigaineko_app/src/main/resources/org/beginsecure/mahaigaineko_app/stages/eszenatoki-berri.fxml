<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane stylesheets="@../../../../styles/eszenatoki-berria.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.beginsecure.mahaigaineko_app.controller.stages.EszenatokiBerriaController">

    <!-- CENTRADOR -->
    <StackPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- PANEL -->
        <VBox styleClass="form-card">

            <Label styleClass="header-title" text="Eszenatoki berri bat sortu" />

            <TextField fx:id="izenaField" promptText="Izena" />
            <TextField fx:id="lekuaField" promptText="Lekua (helbidea/ubicación)" />

            <TextField fx:id="aforoaField" promptText="Aforoa (adib. 1800)" />
            <TextField fx:id="emailaField" promptText="Emaila (aukerakoa)" />
            <TextField fx:id="telefonoaField" promptText="Telefonoa (aukerakoa)" />

            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="btnSave" onAction="#saveStage" styleClass="btn-add" text="Guardar" />
                <Button fx:id="btnCancel" onAction="#cancelStage" styleClass="btn-cancel" text="Cancelar" />
            </HBox>

        </VBox>
    </StackPane>
</AnchorPane>
