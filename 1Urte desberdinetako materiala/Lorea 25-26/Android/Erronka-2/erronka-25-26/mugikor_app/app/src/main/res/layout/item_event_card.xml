<?xml version="1.0" encoding="utf-8"?>
<!-- Layout: item_event_card.xml -> HomeAdapter.EventVH (MainActivity-ko home zerrendan erabiltzen da) -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <!-- CARD-AREN EDUKIA: ikonoa + izenburua + data/ordua + prezioa + saskia -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- IKONOAREN KAXA (kolore urdina) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconBox"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:backgroundTint="#1F4DB8"
            app:cardCornerRadius="14dp"
            android:padding="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- IKONOA (kategoriaren arabera aldatzen da: movie/theatre/mic...) -->
            <!-- IKONOA (kategoriaren arabera) -->
            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:src="@drawable/ic_movie"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <!-- IZENA: ekitaldiaren titulua -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/eventCard_izenburua"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iconBox"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iconBox" />

        <!-- DATA + ORDUA (formatua: “YYYY-MM-DD · HH:MM”) -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/eventCard_data"
            android:textColor="#6B7280"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- PREZIOA -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/eventCard_prezioa"
            android:textColor="#2563EB"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvDate" />

        <!-- SASKI BOTOIA: “erosi/xehetasunetara” joateko ekintza -->
        <ImageButton
            android:id="@+id/btnCart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_cart_circle"
            android:src="@drawable/ic_cart"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@android:color/white" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>