<?xml version="1.0" encoding="utf-8"?>
<!-- Layout: item_list_card.xml -> ListAdapter.VH (Pelikulak/Antzerkiak/Kontzertuak zerrendetan erabiltzen da: activity_list.xml) -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <!-- CARD-AREN EDUKIA: ikonoa + titulua + aretoa + data + ordua + prezioa + saskia -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- IKONOAREN KAXA (urdina) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconBox"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:backgroundTint="#1F4DB8"
            app:cardCornerRadius="14dp"
            android:padding="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- IKONOA (kategoriaren arabera) -->
            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:src="@drawable/ic_movie"
                app:tint="@color/white" />

        </com.google.android.material.card.MaterialCardView>

        <!-- TITULUA (prezioaren ezkerrean moztu dadin) -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/listCard_izenburua"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iconBox"
            app:layout_constraintEnd_toStartOf="@id/tvPrice"
            app:layout_constraintTop_toTopOf="@id/iconBox" />

        <!-- ARETOA / GELA -->
        <TextView
            android:id="@+id/tvRoom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/listCard_eszenatokia"
            android:textColor="#6B7280"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- DATA -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/listCard_data"
            android:textColor="#6B7280"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvRoom" />

        <!-- ORDUA -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/listCard_ordua"
            android:textColor="#6B7280"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvDate" />

        <!-- PREZIOA (eskuinean, nabarmenduta) -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/listCard_prezioa"
            android:textColor="#2563EB"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iconBox" />

        <!-- SASKI BOTOIA: erosketa/xehetasunetara -->
        <ImageButton
            android:id="@+id/btnCart"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_cart_circle"
            android:src="@drawable/ic_cart"
            android:focusable="true"
            android:clickable="true"
            app:tint="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>