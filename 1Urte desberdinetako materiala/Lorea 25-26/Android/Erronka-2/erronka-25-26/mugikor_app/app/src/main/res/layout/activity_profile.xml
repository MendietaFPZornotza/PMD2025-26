<?xml version="1.0" encoding="utf-8"?>
<!-- Activity: NireProfilaActivity (activity_profile.xml) -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="#3F51B5">

    <!-- GOIKO BARRA / TOOLBAR: titulua + atzera botoia -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="Nire profila"
        app:titleTextColor="@android:color/white" />

    <!-- EDUKI NAGUSIA: scroll-a (profila luzea delako) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AVATAR / IKONOA: zirkulu urdina + pertsona ikonoa -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/avatarCircle"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="18dp"
                android:backgroundTint="#1F4DB8"
                app:cardCornerRadius="44dp"
                app:cardElevation="6dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    app:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>

            <!-- TXARTELA (CARD): datu pertsonalak (read-only + edit mode) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPersonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- HEADER: titulua + Editatu/Gorde botoia -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvPersonalTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_datuPertsonalak"
                            android:textColor="#1730B8"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEdit"
                            android:layout_width="100dp"
                            android:layout_height="36dp"
                            android:text="@string/profile_editatu"
                            app:cornerRadius="12dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- IZENA: etiketa -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/profile_izena"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <!-- IZENA (READ-ONLY): tvName -->
                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="#F3F4F6"
                        android:padding="12dp"
                        android:text="@string/profile_gap"
                        android:textColor="#111827" />

                    <!-- IZENA (EDIT): tilName + etName (hasieran ezkutuan) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/profile_izenaHint"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- EMAIL: etiketa -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/profile_mail"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <!-- EMAIL (READ-ONLY): tvEmail -->
                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="#F3F4F6"
                        android:padding="12dp"
                        android:text="@string/profile_gap"
                        android:textColor="#111827" />

                    <!-- EMAIL (EDIT): tilEmail + etEmail (hasieran ezkutuan) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/profile_mailHint"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PASAHITZA: soilik edit moduan agertzen da (aukerakoa) -->
                    <TextView
                        android:id="@+id/tvPassLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/profile_passBerria"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <!-- PASAHITZA 1 (EDIT) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPass"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:visibility="gone"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPass"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/profile_passBerriaHint"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PASAHITZA 2 (EDIT): errepikapena -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPass2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPass2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/profile_passErrepikatu"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TXARTELA (CARD): nire sarrerak (RecyclerView + empty mezua) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTickets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- ATAL IZENBURUA -->
                    <TextView
                        android:id="@+id/tvTicketsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_nireSarrerak"
                        android:textColor="#1730B8"
                        android:textStyle="bold" />

                    <!-- TICKET ZERRENDA -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvMyTickets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <!-- EMPTY STATE: sarrerarik ez dagoenean -->
                    <TextView
                        android:id="@+id/tvTicketsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#F3F4F6"
                        android:padding="12dp"
                        android:text="@string/profile_sarrerarikEz"
                        android:textColor="#6B7280" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TXARTELA (CARD): kontua ezabatu (abisua + botoi gorria) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- ATAL IZENBURUA (gorriz): kontua ezabatu -->
                    <TextView
                        android:id="@+id/tvBtnTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_kontuaEzabatu"
                        android:textColor="#D32F2F"
                        android:textStyle="bold" />

                    <!-- ABISUA: zer gertatzen den ezabatzean -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_kontuz"
                        android:textSize="12sp"
                        android:textColor="#393B3E"
                        android:layout_marginTop="16dp" />

                    <!-- EKINTZA BOTOIA: ezabatu (confirm dialog-arekin) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDelete"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="20dp"
                        android:text="@string/profile_kontuaEzabatu"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="#D32F2F"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_delete"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="@android:color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>