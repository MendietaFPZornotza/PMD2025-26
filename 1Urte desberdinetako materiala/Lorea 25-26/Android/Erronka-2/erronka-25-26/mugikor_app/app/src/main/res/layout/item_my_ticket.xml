<!-- Layout: item_my_ticket.xml -> MyTicketsAdapter.VH (NireProfilaActivity-ko “Nire sarrerak” zerrenda) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp">

    <!-- EKITALDIAREN IZENA (ezkerrean) -->
    <TextView
        android:id="@+id/tvEventTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#111827"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDownload"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- META-INFORMAZIOA: data · ordua · aretoa -->
    <TextView
        android:id="@+id/tvEventMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#6B7280"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/tvEventTitle"
        app:layout_constraintEnd_toStartOf="@id/btnDownload"
        app:layout_constraintTop_toBottomOf="@id/tvEventTitle" />

    <!-- KOPURUA: zenbat sarrera talde honetan (x2, x3...) -->

    <!-- BOTOIA: deskargatu (kodearekin PDFa eskuratzeko) -->

    <TextView
        android:id="@+id/tvCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:text="x2"
        android:textColor="#1730B8"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tvEventTitle"
        app:layout_constraintEnd_toStartOf="@id/btnDownload"
        app:layout_constraintHorizontal_bias="0.931"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDownload"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="4dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:text=""
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_download"
        app:iconSize="30dp"
        app:iconGravity="top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>