<?xml version="1.0" encoding="utf-8"?>
<!-- Activity: TicketQrActivity (activity_ticket_qr.xml) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- GOIKO HEADER-A: degradatua + “erosketa eginda” mezua -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="190dp"
        android:background="@drawable/bg_gradient"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- IKONOA: check (erosketa ondo) -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_check_circle" />

        <!-- TITULUA: egoera -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ticket_erosketaEginda"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:layout_marginTop="10dp"/>

        <!-- AZPITITULUA: azalpena -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ticket_sarreraPrest"
            android:textColor="@android:color/white"
            android:alpha="0.9"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- EDUKI NAGUSIA: scroll (eduki asko dagoelako) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TXARTELA (CARD): deskarga-kodea + kopiatzeko botoia -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center_horizontal"
                    android:layout_height="match_parent"
                    android:layout_width="match_parent">

                    <!-- ATAL IZENBURUA -->
                    <TextView
                        android:text="@string/ticket_deskargaKodea"
                        android:textStyle="bold"
                        android:textColor="#1730B8"
                        android:textSize="16sp"
                        android:layout_height="match_parent"
                        android:layout_width="match_parent"/>

                    <!-- KODEA (controller-ek betetzen du) -->
                    <TextView
                        android:id="@+id/tvDownloadCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/ticket_kodea"
                        android:textStyle="bold"
                        android:textSize="28sp"
                        android:letterSpacing="0.12"
                        android:textColor="#111827"/>

                    <!-- EKINTZA: kopiatu (clipboard-era) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopy"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/ticket_kopiatu"
                        app:icon="@drawable/ic_copy"
                        app:cornerRadius="14dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TXARTELA (CARD): “Xehetasunak” / info osagarria (orain hutsik dago) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp"/>

            <!-- TXARTELA (CARD): email bidez bidalketaren mezua -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                android:backgroundTint="#EFF6FF"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="@string/ticket_infoMail"
                    android:textColor="#1F4DB8"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- BOTOIA: hasierara bueltatu -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHome"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/ticket_btnHasiera"
                app:cornerRadius="14dp"/>

            <!-- BOTOIA: nire sarrerak ikusi (outlined) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMyTickets"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:text="@string/ticket_btnSarreral"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="14dp"/>

            <!-- OIN-OHARRA: gomendioak -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:text="@string/ticket_infoGomendatu"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>